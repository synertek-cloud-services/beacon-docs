---
import type { Category } from '../data/categories';

interface Props {
  category: Category;
  articleCount: number;
}

const { category, articleCount } = Astro.props;
const href = `/kb/${category.slug}/`;
---

<a href={href} class="category-card">
  <div class="category-card-icon" set:html={category.icon} />
  <h2 class="category-card-title">{category.label}</h2>
  <p class="category-card-desc">{category.description}</p>
  <span class="category-card-meta">{articleCount} article{articleCount !== 1 ? 's' : ''}</span>
</a>

<style>
  .category-card {
    display: flex;
    flex-direction: column;
    gap: 8px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--r-card);
    padding: 22px 24px 20px;
    text-decoration: none;
    transition: border-color 0.15s, transform 0.15s, box-shadow 0.15s;
  }

  .category-card:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
    box-shadow: var(--shadow);
    text-decoration: none;
  }

  .category-card-icon {
    width: 32px;
    height: 32px;
    color: var(--accent);
    margin-bottom: 4px;
  }

  .category-card-icon :global(svg) {
    width: 32px;
    height: 32px;
  }

  .category-card-title {
    font-size: 15px;
    font-weight: 600;
    color: var(--text);
    line-height: 1.3;
  }

  .category-card-desc {
    font-size: 13px;
    color: var(--muted);
    line-height: 1.5;
    flex: 1;
  }

  .category-card-meta {
    font-size: 11px;
    color: var(--muted);
    margin-top: 4px;
  }
</style>
