---
import type { CollectionEntry } from 'astro:content';
import KBLayout from './KBLayout.astro';
import TOC from '../components/TOC.astro';
import EditLink from '../components/EditLink.astro';
import { CATEGORIES } from '../data/categories';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  article: CollectionEntry<'kb'>;
  headings: Heading[];
}

const { article, headings } = Astro.props;
const { title, category, updated } = article.data;

const cat = CATEGORIES.find(c => c.slug === category);
const hasToc = headings.filter(h => h.depth === 2 || h.depth === 3).length >= 3;

const dateStr = updated.toLocaleDateString('en-US', {
  year: 'numeric', month: 'long', day: 'numeric',
});
---

<KBLayout
  title={`${title} — Beacon Docs`}
  description={`${title} — Beacon documentation`}
  currentId={article.id}
>
  <div class={`article-wrap${hasToc ? ' article-wrap--toc' : ''}`}>
    <div class="article-content">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Docs</a>
        <span class="breadcrumb-sep" aria-hidden="true">/</span>
        {cat && <a href={`/kb/${cat.slug}/`}>{cat.label}</a>}
        <span class="breadcrumb-sep" aria-hidden="true">/</span>
        <span aria-current="page">{title}</span>
      </nav>

      <article>
        <header class="article-header">
          <h1 class="article-title">{title}</h1>
          <p class="article-meta">Updated {dateStr}</p>
        </header>

        <div class="prose" data-pagefind-body>
          <slot />
        </div>
      </article>

      <footer class="article-footer">
        <EditLink id={article.id} />
      </footer>
    </div>

    {hasToc && (
      <aside class="article-toc">
        <TOC headings={headings} />
      </aside>
    )}
  </div>
</KBLayout>

<style>
  .article-wrap {
    display: flex;
    gap: 48px;
    max-width: calc(var(--content-w) + var(--toc-w) + 48px);
  }

  .article-content {
    flex: 1;
    min-width: 0;
    max-width: var(--content-w);
  }

  .article-toc {
    flex-shrink: 0;
    width: var(--toc-w);
    padding-top: 58px; /* align with prose content, below header */
  }

  /* Breadcrumb */
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 12.5px;
    color: var(--muted);
    margin-bottom: 20px;
    flex-wrap: wrap;
  }

  .breadcrumb a {
    color: var(--muted);
    text-decoration: none;
  }

  .breadcrumb a:hover { color: var(--accent); }

  .breadcrumb-sep { color: var(--border-2); }

  .breadcrumb span[aria-current] { color: var(--muted-2); }

  /* Article header */
  .article-header {
    margin-bottom: 28px;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--border);
  }

  .article-title {
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--text);
    line-height: 1.25;
    margin-bottom: 8px;
    letter-spacing: -0.02em;
  }

  .article-meta {
    font-size: 12.5px;
    color: var(--muted);
  }

  /* Article footer */
  .article-footer {
    margin-top: 48px;
    padding-top: 20px;
    border-top: 1px solid var(--border);
  }

  @media (max-width: 1100px) {
    .article-toc { display: none; }
  }
</style>
